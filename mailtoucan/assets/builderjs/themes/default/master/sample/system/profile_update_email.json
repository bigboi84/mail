{
    "theme": "default",
    "name": "PageElement",
    "template": "Page",
    "page_title": "Manage Your Subscription Preferences",
    "blocks": [
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "HeadingElement",
                    "template": "Heading",
                    "type": "h1",
                    "text": "Manage Your Subscription Preferences",
                    "formats": {}
                },
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{LIST_NAME}",
                    "formats": {}
                },
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{CURRENT_DATE}",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 40
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "DividerElement",
                    "template": "Divider",
                    "formats": {
                        "background_color": "#D0D0D0",
                        "height": 2,
                        "divider_style": "solid",
                        "padding_top": 10,
                        "padding_bottom": 10
                    }
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 0,
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "HeadingElement",
                    "template": "Heading",
                    "type": "h2",
                    "text": "Manage how you’d like to hear from us ✨",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "We received a request to update your subscription preferences for <strong>List 1</strong>.",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "If this was you, please confirm and make your changes using the secure link below:",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "LinkElement",
                    "template": "Link",
                    "text": "Update My Preferences",
                    "url": "{UPDATE_PROFILE_URL}",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "If you did not make this request, no action is needed. It may have been submitted by mistake, and your current subscription settings will remain unchanged.",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "Copyright (C). {LIST_NAME} | This is an automated message, please do not reply.",
                    "formats": {
                        "font_size": 13,
                        "text_align": "center"
                    }
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 60
            }
        }
    ],
    "formats": {
        "background_color": "#F4F4F4",
        "padding_top": 40,
        "padding_right": 60,
        "padding_bottom": 40,
        "padding_left": 60
    },
    "block_gap": 0,
    "container_width": "medium",
    "block_padding_bottom": 20,
    "block_padding_top": 20,
    "block_padding_right": 20,
    "block_padding_left": 20
}