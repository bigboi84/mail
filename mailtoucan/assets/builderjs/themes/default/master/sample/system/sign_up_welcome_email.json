                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "Copyright (C). {LIST_NAME} | This is an automated message, please do not reply.",
                    "formats": {
                        "font_size": 13,
                        "text_align": "center"
                    }
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 60
            }
        }
    ],
    "formats": {
        "background_color": "#F4F4F4",
        "padding_top": 40,
        "padding_right": 60,
        "padding_bottom": 40,
        "padding_left": 60
