{
    "theme": "default",
    "name": "PageElement",
    "template": "Page",
    "page_title": "Welcome aboard!",
    "blocks": [
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "HeadingElement",
                    "template": "Heading",
                    "type": "h1",
                    "text": "Subscription Confirmed — Welcome Aboard!",
                    "formats": {}
                },
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{LIST_NAME}",
                    "formats": {}
                },
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{CURRENT_DATE}",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 40
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "DividerElement",
                    "template": "Divider",
                    "formats": {
                        "background_color": "#D0D0D0",
                        "height": 2,
                        "divider_style": "solid",
                        "padding_top": 10,
                        "padding_bottom": 10
                    }
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 0,
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "HeadingElement",
                    "template": "Heading",
                    "type": "h2",
                    "text": "Your subscription has been successfully recorded 🎉",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "For your records, here is a copy of the information you submitted to us:",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{SUBSCRIBER_SUMMARY}",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "If at any time you wish to stop receiving our emails, you can:",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "LinkElement",
                    "template": "Link",
                    "text": "Unsubscribe Here",
