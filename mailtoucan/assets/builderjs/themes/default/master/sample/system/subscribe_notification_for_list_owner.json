{
    "theme": "default",
    "name": "PageElement",
    "template": "Page",
    "page_title": "New Subscription Notification",
    "blocks": [
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "HeadingElement",
                    "template": "Heading",
                    "type": "h1",
                    "text": "New Subscription Notification",
                    "formats": {}
                },
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{LIST_NAME}",
                    "formats": {}
                },
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "{CURRENT_DATE}",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 40
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "DividerElement",
                    "template": "Divider",
                    "formats": {
                        "background_color": "#D0D0D0",
                        "height": 2,
                        "divider_style": "solid",
                        "padding_top": 10,
                        "padding_bottom": 10
                    }
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 0,
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "HeadingElement",
                    "template": "Heading",
                    "type": "h2",
                    "text": "A new subscriber has joined your list",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "This is an automated notification to inform you that a new subscriber has been added to your list <strong>{LIST_NAME}</strong>:",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "• <span class=\"fw-bold\">Name:</span> {SUBSCRIBER_FIRST_NAME} {SUBSCRIBER_LAST_NAME}<br>• <span class=\"fw-bold\">Email:</span> {SUBSCRIBER_EMAIL}",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "No further action is required. This message is provided for your records only.",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "If this subscription was unexpected, you may wish to review your list settings or contact support for further details. Otherwise, you can safely archive this message.",
                    "formats": {}
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_bottom": 0
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
                    "text": "Copyright (C). {LIST_NAME} | This is an automated message, please do not reply.",
                    "formats": {
                        "font_size": 13,
                        "text_align": "center"
                    }
                }
            ],
            "formats": {
                "background_color": "#FFFFFF",
                "padding_top": 60
            }
        }
    ],
    "formats": {
        "background_color": "#F4F4F4",
        "padding_top": 40,
        "padding_right": 60,
        "padding_bottom": 40,
        "padding_left": 60
    },
    "block_gap": 0,
    "container_width": "medium",
    "block_padding_bottom": 20,
    "block_padding_top": 20,
    "block_padding_right": 20,
    "block_padding_left": 20
}