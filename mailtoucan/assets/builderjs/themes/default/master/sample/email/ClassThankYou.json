                        {
                            "link": "#",
                            "image_url": "master/assets/image/ClassThankYou/instagram.png",
                            "label": "Instagram"
                        },
                        {
                            "link": "#",
                            "image_url": "master/assets/image/ClassThankYou/twitter.png",
                            "label": "X"
