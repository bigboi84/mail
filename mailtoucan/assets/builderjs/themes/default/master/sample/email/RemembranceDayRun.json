                        "font_size": 14,
                        "text_align": "center",
                        "text_decoration": "underline"
                    }
                }
            ],
            "formats": {
                "padding_top": 10,
                "padding_bottom": 10
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
