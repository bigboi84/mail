                        },
                        {
                            "image_url": "master/assets/image/icons/twitter.png",
                            "link": "#",
                            "label": "Twitter"
                        },
                        {
                            "image_url": "master/assets/image/icons/instagram.png",
                            "link": "#",
                            "label": "Instagram"
                        }
                    ],
                    "size": 30,
                    "gap": 30,
                    "align": "center",
                    "formats": {
                        "background_position": "center",
                        "background_size": "100%",
                        "background_repeat": "no-repeat"
                    }
                }
            ],
            "formats": {
                "padding_top": 0,
                "padding_bottom": 0
