                    "text": "Copyright (C) {CURRENT_YEAR}. All rights reserved.",
                    "formats": {
                        "font_family": "'Helvetica Neue', Helvetica, Arial, Verdana, sans-serif",
                        "font_size": 12,
                        "text_align": "center"
                    }
                }
            ],
            "formats": {
                "padding_top": 10,
                "padding_bottom": 20
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "PElement",
                    "template": "P",
