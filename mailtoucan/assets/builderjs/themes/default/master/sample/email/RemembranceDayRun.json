                    "formats": {
                        "background_position": "center",
                        "background_size": "100%",
                        "background_repeat": "no-repeat",
                        "padding_top": 0,
                        "padding_right": 0,
                        "padding_bottom": 0,
                        "padding_left": 0,
                        "width": "100%",
                        "height": "auto",
                        "align": "center",
                        "border_radius": 30
                    },
                    "effect": {
                        "grayscale": null,
                        "sepia": null,
                        "invert": null,
                        "blur": null,
                        "brightness": null,
                        "contrast": null,
                        "saturate": null,
                        "hueRotate": null,
                        "opacity": null
                    }
                }
            ],
            "formats": {
                "background_image": "master/assets/image/remembrance_day_run/footer-bg.png",
                "background_position": "top center",
                "background_repeat": "no-repeat",
                "padding_top": 0,
                "padding_right": 0,
                "padding_bottom": 20,
                "padding_left": 0
