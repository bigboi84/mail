                        "font_family": "'Helvetica Neue', Helvetica, Arial, Verdana, sans-serif",
                        "font_size": 12,
                        "text_align": "center"
                    }
                }
            ],
            "formats": {
                "padding_top": 0,
                "padding_bottom": 30
            }
