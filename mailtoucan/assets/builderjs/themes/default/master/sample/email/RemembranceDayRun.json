                        "font_family": "inherit",
                        "font_weight": "400",
                        "font_size": 18,
                        "text_color": "#f10200",
                        "link_color": "#f10200",
                        "text_align": "center",
                        "line_height": "1.5",
                        "text_direction": "ltr",
                        "background_color": "#fff",
                        "background_position": "center",
                        "background_size": "100%",
                        "background_repeat": "no-repeat",
                        "padding_top": 8,
                        "padding_right": 80,
                        "padding_bottom": 8,
                        "padding_left": 80,
                        "border_top_style": "solid",
                        "border_top_width": 2,
                        "border_top_color": "#f10200",
                        "border_right_style": "solid",
                        "border_right_width": 2,
                        "border_right_color": "#f10200",
                        "border_bottom_style": "solid",
                        "border_bottom_width": 2,
                        "border_bottom_color": "#f10200",
                        "border_left_width": 2,
                        "border_left_style": "solid",
                        "border_left_color": "#f10200",
                        "border_radius": 8
                    }
                }
            ],
            "formats": {
                "background_color": "#f6f5f1",
                "padding_bottom": 60
            }
        },
        {
            "name": "BlockElement",
            "template": "Block",
            "elements": [
                {
                    "name": "ImageElement",
                    "template": "Image",
                    "src": "master/assets/image/remembrance_day_run/topBanner.png",
