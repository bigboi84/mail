                                        {
                                            "name": "H2Element",
                                            "template": "H2",
                                            "text": "The Science of Soil: Understanding Your Plant's Needs",
                                            "formats": {
                                                "font_family": "Lora, Georgia, 'Times New Roman', serif",
                                                "font_weight": "bold",
                                                "font_size": 32,
                                                "text_color": "#1e4634",
